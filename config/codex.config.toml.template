# OpenAI Codex — Media MCP Server
# Global:  %USERPROFILE%\.codex\config.toml
# Project:  .codex\config.toml  (requires trusted project in Codex)
#
# Replace INSTALL_DIR with your installation path.

[mcp_servers.media-mcp-server]
command = "INSTALL_DIR/bin/MediaMCPServer.exe"
args = []
cwd = "INSTALL_DIR/bin"
enabled = true
startup_timeout_sec = 30
tool_timeout_sec = 120

# Optional environment (uncomment if needed):
# [mcp_servers.media-mcp-server.env]
# MEDIA_MCP_DATA_PATH = "INSTALL_DIR/data/media"
# MEDIA_MCP_DEBUG = "1"
